# HyperFlow Conductor configuration
# Copy to .env and adjust as needed.

# LLM API keys
ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_API_KEY=...

# Conductor settings (override via HF_CONDUCTOR_ prefix)
# HF_CONDUCTOR_AUTO_APPROVE=false
# HF_CONDUCTOR_LLM__DEFAULT_PROVIDER=anthropic
# HF_CONDUCTOR_KUBERNETES__CLUSTER_NAME=hyperflow-test
# HF_CONDUCTOR_VERBOSE=false
# HF_CONDUCTOR_LOG_LEVEL=INFO

# External repo paths
# HF_CONDUCTOR_HYPERFLOW_K8S_DEPLOYMENT_PATH=../../hyperflow-k8s-deployment
# HF_CONDUCTOR_KUBERNETES__KIND_CONFIG=local/kind-config-3n.yaml
